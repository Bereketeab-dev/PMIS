{
    "name": "Variation Order",
    "engine": "InnoDB",
    "description": "Manages variation orders, scope changes, and their cost/time impacts.",
    "creation": "2024-03-10 12:15:00.000000",
    "modified": "2024-03-10 12:15:00.000000",
    "modified_by": "Administrator",
    "owner": "Administrator",
    "docstatus": 0,
    "idx": 0,
    "issingle": 0,
    "istable": 0,
    "editable_grid": 1,
    "track_changes": 1,
    "autoname": "format:VO-{project}-{#####}",
    "sort_field": "modified",
    "sort_order": "DESC",
    "title_field": "variation_title",
    "search_fields": "variation_title, project, status, type_of_variation",
    "track_seen": 1,
    "permissions": [
        {
            "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Quantity Surveyor", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 0, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Client Representative", "read": 1, "write": 0, "create": 0, "report": 1, "share": 1}
    ],
    "links": [
        {"link_doctype": "Project", "link_fieldname": "project"},
        {"link_doctype": "RFI", "link_fieldname": "originating_rfi"},
        {"link_doctype": "Cost Estimate", "link_fieldname": "linked_cost_estimate"}
    ],
    "fields": [
        {
            "fieldname": "variation_title",
            "label": "Variation Title / Subject",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "project",
            "label": "Project",
            "fieldtype": "Link",
            "options": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Draft\nPending Approval\nApproved\nRejected\nImplemented\nCancelled",
            "default": "Draft",
            "in_list_view": 1,
            "read_only_on_submit": 1
        },
        {
            "fieldname": "variation_date",
            "label": "Variation Date",
            "fieldtype": "Date",
            "default": "Today",
            "reqd": 1
        },
        {
            "fieldname": "initiated_by",
            "label": "Initiated By",
            "fieldtype": "Link",
            "options": "User",
            "default": "__user",
            "read_only": 1
        },
        {
            "fieldname": "type_of_variation",
            "label": "Type of Variation",
            "fieldtype": "Select",
            "options": "Addition\nOmission\nSubstitution\nDesign Change\nInstruction\nOther",
            "in_list_view": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "originating_rfi",
            "label": "Originating RFI (if any)",
            "fieldtype": "Link",
            "options": "RFI"
        },
        {
            "fieldname": "client_instruction_ref",
            "label": "Client Instruction Ref.",
            "fieldtype": "Data"
        },
        {
            "fieldname": "description_tab",
            "label": "Description of Variation",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "description_of_change",
            "label": "Detailed Description of Change",
            "fieldtype": "TextEditor",
            "reqd": 1
        },
        {
            "fieldname": "reason_for_variation",
            "label": "Reason for Variation",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "scope_of_works_affected",
            "label": "Scope of Works Affected",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "attachments",
            "label": "Supporting Documents/Drawings",
            "fieldtype": "Attach"
        },
        {
            "fieldname": "impact_tab",
            "label": "Impact Assessment",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "cost_impact_section",
            "label": "Cost Impact",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "cost_impact_type",
            "label": "Cost Impact Type",
            "fieldtype": "Select",
            "options": "Addition\nDeduction\nNo Change",
            "default": "No Change",
            "reqd": 1
        },
        {
            "fieldname": "estimated_cost_impact",
            "label": "Estimated Cost Impact",
            "fieldtype": "Currency",
            "options": "project.company_currency",
            "description": "Net financial impact. Positive for addition, negative for deduction."
        },
        {
            "fieldname": "linked_cost_estimate",
            "label": "Linked Cost Estimate for Variation",
            "fieldtype": "Link",
            "options": "Cost Estimate",
            "description": "If a detailed breakdown is required, link to a Cost Estimate document."
        },
        {
            "fieldname": "schedule_impact_section",
            "label": "Schedule Impact",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "schedule_impact_type",
            "label": "Schedule Impact Type",
            "fieldtype": "Select",
            "options": "Extension of Time\nAcceleration\nNo Change",
            "default": "No Change"
        },
        {
            "fieldname": "estimated_time_impact_days",
            "label": "Estimated Time Impact (Days)",
            "fieldtype": "Int",
            "description": "Positive for extension, negative for acceleration (if applicable)."
        },
        {
            "fieldname": "impact_on_contract_completion_date",
            "label": "Impact on Contract Completion Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "other_impacts",
            "label": "Other Impacts (Quality, Resources, etc.)",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "approval_tab",
            "label": "Approval Details",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "approved_by_client",
            "label": "Approved by Client",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "client_approval_date",
            "label": "Client Approval Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "approved_by_consultant",
            "label": "Approved by Consultant",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "consultant_approval_date",
            "label": "Consultant Approval Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "internal_approval_by",
            "label": "Internal Approval By",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "internal_approval_date",
            "label": "Internal Approval Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "approval_remarks",
            "label": "Approval Remarks",
            "fieldtype": "TextEditor"
        }
    ],
