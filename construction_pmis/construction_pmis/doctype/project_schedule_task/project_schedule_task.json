{
    "name": "Project Schedule Task",
    "engine": "InnoDB",
    "description": "Detailed task management for construction project schedules.",
    "creation": "2024-03-10 14:15:00.000000",
    "modified": "2024-03-10 14:15:00.000000",
    "modified_by": "Administrator",
    "owner": "Administrator",
    "docstatus": 0,
    "idx": 0,
    "issingle": 0,
    "istable": 0,
    "editable_grid": 1,
    "track_changes": 1,
    "autoname": "format:TASK-{project}-{#####}",
    "sort_field": "start_date",
