            "fieldtype": "Table",
            "options": "Project Task Predecessor"
        },
        {
            "fieldname": "resources_tab",
            "label": "Resources",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "assigned_manpower",
            "label": "Assigned Manpower",
            "fieldtype": "Table",
            "options": "Task Assigned Manpower",
            "description": "Manpower resources assigned to this task."
        },
        {
            "fieldname": "assigned_machinery",
            "label": "Assigned Machinery",
            "fieldtype": "Table",
            "options": "Task Assigned Machinery",
            "description": "Machinery resources assigned to this task."
        },
        {
            "fieldname": "notes_tab",
            "label": "Notes & Attachments",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "notes",
            "label": "Notes",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "attachments",
            "label": "Attachments",
            "fieldtype": "Attach"
        }
    ]
}
