            "reqd": 1,
            "in_list_view": 1,
            "fetch_from": "daily_work_plan_manpower.resource_type"
        },
        {
            "fieldname": "specific_employee",
            "label": "Specific Employee",
            "fieldtype": "Link",
            "options": "Employee",
            "fetch_from": "daily_work_plan_manpower.specific_employee"
        },
        {
            "fieldname": "actual_quantity",
            "label": "Actual Quantity Present",
            "fieldtype": "Int",
            "reqd": 1,
            "in_list_view": 1,
            "fetch_from": "daily_work_plan_manpower.planned_quantity"
        },
        {
            "fieldname": "actual_hours_worked",
            "label": "Actual Hours Worked",
            "fieldtype": "Float",
            "reqd": 1,
            "default": 8,
            "fetch_from": "daily_work_plan_manpower.planned_hours"
        },
        {
            "fieldname": "overtime_hours",
            "label": "Overtime Hours",
            "fieldtype": "Float",
            "default": 0
        },
        {
            "fieldname": "task_worked_on",
            "label": "Task Worked On (Optional)",
            "fieldtype": "Link",
            "options": "Daily Log Task Progress"
        },
        {
            "fieldname": "remarks",
            "label": "Remarks",
            "fieldtype": "Small Text"
        }
    ]
