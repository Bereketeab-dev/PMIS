    "autoname": "Prompt",
    "permissions": [],
    "fields": [
        {
            "fieldname": "machinery_plan_item",
            "label": "From Project Machinery Plan",
            "fieldtype": "Link",
            "options": "Machinery Plan Item",
            "get_query": "construction_pmis.construction_pmis.utils.get_machinery_plan_items_for_project_daily"
        },
        {
            "fieldname": "machinery_asset",
            "label": "Specific Machinery/Asset",
            "fieldtype": "Link",
            "options": "Asset",
            "fetch_from": "machinery_plan_item.machinery_asset"
        },
        {
            "fieldname": "machinery_type",
            "label": "Machinery Type",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1,
            "fetch_from": "machinery_plan_item.machinery_type"
        },
        {
            "fieldname": "planned_quantity",
            "label": "Planned Quantity",
            "fieldtype": "Int",
            "reqd": 1,
            "default": 1,
            "in_list_view": 1,
            "fetch_from": "machinery_plan_item.required_quantity"
        },
        {
            "fieldname": "planned_hours",
            "label": "Planned Operational Hours",
            "fieldtype": "Float",
            "default": 8,
            "fetch_from": "machinery_plan_item.planned_hours_per_day"
        },
        {
            "fieldname": "assigned_task",
            "label": "Assigned Task (Optional)",
            "fieldtype": "Link",
            "options": "Daily Work Plan Task"
        },
        {
            "fieldname": "operator_name",
            "label": "Operator Name(s)",
            "fieldtype": "Small Text"
        },
        {
            "fieldname": "notes",
            "label": "Notes",
            "fieldtype": "Small Text"
        }
    ]
