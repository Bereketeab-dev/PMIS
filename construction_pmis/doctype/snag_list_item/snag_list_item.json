        {"link_doctype": "Site Inspection", "link_fieldname": "source_inspection"}
    ],
    "fields": [
        {
            "fieldname": "description",
            "label": "Snag Description",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "project",
            "label": "Project",
            "fieldtype": "Link",
            "options": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Open\nAssigned\nWork In Progress\nRectified\nPending Re-inspection\nClosed\nRejected",
            "default": "Open",
            "in_list_view": 1
        },
        {
            "fieldname": "priority",
            "label": "Priority",
            "fieldtype": "Select",
            "options": "Low\nMedium\nHigh\nCritical",
            "default": "Medium",
            "in_list_view": 1
        },
        {
            "fieldname": "date_identified",
            "label": "Date Identified",
            "fieldtype": "Date",
            "default": "Today",
            "reqd": 1
        },
        {
            "fieldname": "identified_by",
            "label": "Identified By",
            "fieldtype": "Link",
            "options": "User",
            "default": "__user"
        },
        {
            "fieldname": "location",
            "label": "Location of Snag",
            "fieldtype": "Small Text",
            "reqd": 1,
            "description": "e.g., Apartment 101 - Master Bedroom, Zone B - Column C3"
        },
        {
            "fieldname": "source_inspection",
            "label": "Source Site Inspection (if any)",
            "fieldtype": "Link",
            "options": "Site Inspection"
        },
        {
            "fieldname": "snag_type_category",
            "label": "Snag Type / Category",
            "fieldtype": "Select",
            "options": "Architectural\nStructural\nMEP - Electrical\nMEP - Plumbing\nMEP - HVAC\nFinishing\nSafety\nOther",
            "description": "Helps in categorizing and assigning."
        },
        {
            "fieldname": "details_tab",
            "label": "Snag Details & Rectification",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "detailed_description",
            "label": "Detailed Description (Optional)",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "photo_evidence",
            "label": "Photo Evidence",
            "fieldtype": "Attach Image"
        },
        {
            "fieldname": "assigned_to_party",
            "label": "Assigned To (Contractor/Party)",
            "fieldtype": "Link",
            "options": "Supplier",
            "description": "Subcontractor or party responsible for rectification."
        },
        {
            "fieldname": "assigned_to_user",
            "label": "Assigned To (User - Internal)",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "target_rectification_date",
            "label": "Target Rectification Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "rectification_details_tab",
            "label": "Rectification & Closure",
            "fieldtype": "Tab Break"
        },
        {
            "fieldname": "rectification_action_taken",
            "label": "Action Taken for Rectification",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "rectified_photo_evidence",
            "label": "Photo Evidence of Rectification",
            "fieldtype": "Attach Image"
        },
        {
            "fieldname": "date_rectified",
            "label": "Date Rectified",
            "fieldtype": "Date"
        },
        {
            "fieldname": "re_inspected_by",
            "label": "Re-inspected By",
            "fieldtype": "Link",
            "options": "User"
        },
        {
            "fieldname": "re_inspection_date",
            "label": "Re-inspection Date",
            "fieldtype": "Date"
        },
        {
            "fieldname": "re_inspection_status",
            "label": "Re-inspection Status",
            "fieldtype": "Select",
            "options": "\nApproved\nRejected"
        },
        {
            "fieldname": "closure_remarks",
            "label": "Closure Remarks",
            "fieldtype": "TextEditor"
        },
        {
            "fieldname": "date_closed",
            "label": "Date Closed",
            "fieldtype": "Date",
            "read_only": 1
