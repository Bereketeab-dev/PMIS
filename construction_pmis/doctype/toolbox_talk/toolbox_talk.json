{
    "name": "Toolbox Talk",
    "engine": "InnoDB",
    "description": "Records details of toolbox talks conducted on site.",
    "creation": "2024-03-10 18:20:00.000000",
    "modified": "2024-03-10 18:20:00.000000",
    "modified_by": "Administrator",
    "owner": "Administrator",
    "docstatus": 0,
    "idx": 0,
    "issingle": 0,
    "istable": 0,
