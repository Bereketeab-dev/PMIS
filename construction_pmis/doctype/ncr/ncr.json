    "permissions": [
        {
            "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 1, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "QA QC Engineer", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 0, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Site Engineer", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 0, "cancel": 0, "amend": 0, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        },
        {
            "role": "Safety Officer", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 0, "amend": 1, "report": 1, "share": 1, "export": 1, "print": 1, "email": 1
        }
    ],
    "links": [
        {"link_doctype": "Project", "link_fieldname": "project"},
        {"link_doctype": "Site Inspection", "link_fieldname": "source_inspection"}
    ],
    "fields": [
        {
            "fieldname": "subject",
            "label": "Subject / NCR Title",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "project",
            "label": "Project",
            "fieldtype": "Link",
            "options": "Project",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Open\nUnder Investigation\nCorrective Action Proposed\nCorrective Action Implemented\nPending Verification\nClosed\nRejected",
            "default": "Open",
            "in_list_view": 1
        },
        {
            "fieldname": "ncr_type",
            "label": "NCR Type",
            "fieldtype": "Select",
            "options": "Quality\nSafety\nEnvironmental\nMaterial\nWorkmanship\nDocumentation\nOther",
            "default": "Quality",
            "in_list_view": 1
        },
        {
            "fieldname": "severity",
            "label": "Severity / Classification",
            "fieldtype": "Select",
            "options": "Minor\nMajor\nCritical\nObservation",
            "default": "Minor"
        },
        {
            "fieldname": "date_raised",
            "label": "Date Raised",
            "fieldtype": "Date",
            "default": "Today",
            "reqd": 1
        },
        {
            "fieldname": "raised_by",
            "label": "Raised By",
            "fieldtype": "Link",
            "options": "User",
            "default": "__user",
            "read_only": 1
        },
        {
            "fieldname": "source_inspection",
            "label": "Source Site Inspection (if any)",
