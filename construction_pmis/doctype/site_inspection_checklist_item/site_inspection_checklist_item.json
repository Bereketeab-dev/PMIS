{
    "name": "Site Inspection Checklist Item",
    "engine": "InnoDB",
    "description": "Child table for Site Inspection, detailing checklist items and observations.",
    "creation": "2024-03-10 17:45:00.000000",
    "modified": "2024-03-10 17:45:00.000000",
    "modified_by": "Administrator",
    "owner": "Administrator",
    "docstatus": 0,
    "idx": 0,
    "issingle": 0,
    "istable": 1,
    "editable_grid": 1,
    "track_changes": 0,
    "autoname": "Prompt",
    "permissions": [],
    "fields": [
        {
            "fieldname": "template_item_ref",
            "label": "Template Item Ref (Optional)",
            "fieldtype": "Link",
            "options": "Checklist Template Item",
            "description": "Link to the original item from a checklist template."
        },
        {
            "fieldname": "sequence_id",
            "label": "Sequence ID",
            "fieldtype": "Data",
            "in_list_view": 1,
            "fetch_from": "template_item_ref.sequence_id"
        },
        {
            "fieldname": "checkpoint_description",
            "label": "Checkpoint / Question",
            "fieldtype": "Text",
            "reqd": 1,
            "in_list_view": 1,
            "fetch_from": "template_item_ref.checkpoint_description"
        },
        {
            "fieldname": "expected_outcome_criteria",
            "label": "Expected Outcome / Criteria",
            "fieldtype": "Small Text",
            "fetch_from": "template_item_ref.expected_outcome_criteria",
            "read_only": 1
        },
        {
            "fieldname": "observation_status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Pass\nFail\nN/A (Not Applicable)\nObservation",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "actual_observation",
            "label": "Actual Observation / Remarks",
            "fieldtype": "Text"
        },
        {
            "fieldname": "attached_photo",
            "label": "Attach Photo (Optional)",
            "fieldtype": "Attach Image"
        },
        {
            "fieldname": "corrective_action_needed",
            "label": "Corrective Action Needed?",
            "fieldtype": "Check",
            "default": 0,
            "depends_on": "eval:doc.observation_status=='Fail' || doc.observation_status=='Observation'"
        },
        {
            "fieldname": "ncr_raised_link",
            "label": "Linked NCR",
            "fieldtype": "Link",
            "options": "NCR",
            "description": "Link to NCR if raised for this item."
        }
    ]
}
