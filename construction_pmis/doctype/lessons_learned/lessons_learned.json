        },
        {
            "fieldname": "phase_of_project",
            "label": "Phase of Project When Lesson Occurred",
            "fieldtype": "Select",
            "options": "Initiation\nPlanning\nDesign\nProcurement\nExecution\nMonitoring & Control\nCloseout\nPost-Project",
