            "fetch_from": "daily_work_plan_machinery.machinery_asset"
        },
        {
            "fieldname": "machinery_type",
            "label": "Machinery Type",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1,
            "fetch_from": "daily_work_plan_machinery.machinery_type"
        },
        {
            "fieldname": "actual_quantity",
