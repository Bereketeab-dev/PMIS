            "fieldtype": "Small Text",
            "fetch_from": "daily_work_plan_machinery.operator_name"
        },
        {
            "fieldname": "task_worked_on",
            "label": "Task Worked On (Optional)",
            "fieldtype": "Link",
            "options": "Daily Log Task Progress"
        },
        {
            "fieldname": "remarks",
            "label": "Remarks (e.g., fuel consumption, issues)",
            "fieldtype": "Small Text"
