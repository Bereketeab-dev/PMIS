    "permissions": [],
    "fields": [
        {
            "fieldname": "project_schedule_task",
            "label": "Project Schedule Task",
            "fieldtype": "Link",
            "options": "Project Schedule Task",
            "in_list_view": 1,
            "get_query": "construction_pmis.construction_pmis.utils.get_tasks_for_daily_plan"
        },
        {
            "fieldname": "task_name",
            "label": "Task Name / Description",
            "fieldtype": "Data",
