{
 "doctype": "Workflow",
 "document_type": "NCR",
 "is_active": 1,
 "module": "Construction PMIS",
 "name": "NCR Workflow",
 "send_email_alert": 1,
 "states": [
  {
   "allow_edit": "QA QC Engineer,Site Engineer,Safety Officer,Project Manager",
   "doc_status": "0",
   "message": "NCR raised and is open.",
   "state": "Open"
  },
  {
   "allow_edit": "QA QC Engineer,Project Manager",
   "doc_status": "1",
   "message": "NCR is under investigation for root cause and impact.",
   "state": "Under Investigation"
  },
  {
   "allow_edit": "QA QC Engineer,Project Manager",
   "doc_status": "1",
   "message": "Corrective and preventive actions have been proposed.",
   "state": "Corrective Action Proposed"
  },
  {
   "allow_edit": "QA QC Engineer,Project Manager,Site Engineer",
   "doc_status": "1",
   "message": "Corrective actions have been implemented.",
   "state": "Corrective Action Implemented"
  },
  {
   "allow_edit": "QA QC Engineer,Project Manager",
   "doc_status": "1",
   "message": "Implemented actions are pending verification for effectiveness.",
   "state": "Pending Verification"
  },
  {
   "allow_edit": "System Manager",
   "doc_status": "1",
   "message": "NCR verified and closed.",
   "state": "Closed",
   "update_field": "status",
   "update_value": "Closed"
  },
  {
   "allow_edit": "QA QC Engineer,Project Manager",
   "doc_status": "2",
   "message": "NCR has been rejected as invalid or duplicated.",
   "state": "Rejected"
  }
 ],
 "transitions": [
  {
   "action": "Start Investigation",
   "allow_self_approval": 1,
   "allowed": "QA QC Engineer,Project Manager",
   "next_state": "Under Investigation",
   "state": "Open"
  },
  {
   "action": "Reject NCR",
   "allowed": "QA QC Engineer,Project Manager",
   "custom_action_method": "reject_ncr",
   "next_state": "Rejected",
   "state": "Open"
  },
  {
   "action": "Propose Corrective Action",
   "allowed": "QA QC Engineer,Project Manager",
   "condition": "doc.proposed_corrective_action && doc.action_assigned_to",
   "custom_action_method": "propose_corrective_action",
   "next_state": "Corrective Action Proposed",
   "state": "Under Investigation"
  },
  {
   "action": "Confirm Action Implementation",
   "allowed": "Site Engineer,Project Manager,QA QC Engineer",
   "condition": "doc.action_taken_details && doc.action_completion_date",
   "custom_action_method": "implement_corrective_action",
   "next_state": "Corrective Action Implemented",
   "state": "Corrective Action Proposed"
  },
  {
   "action": "Submit for Verification",
   "allow_self_approval": 0,
   "allowed": "Site Engineer,Project Manager,QA QC Engineer",
   "next_state": "Pending Verification",
   "state": "Corrective Action Implemented"
  },
  {
   "action": "Verify and Close",
   "allowed": "QA QC Engineer,Project Manager",
   "condition": "doc.verification_by && doc.verification_date && doc.verification_remarks",
   "custom_action_method": "verify_and_close_ncr",
   "next_state": "Closed",
   "state": "Pending Verification"
  },
  {
   "action": "Verification Failed (Re-do Action)",
   "allowed": "QA QC Engineer,Project Manager",
   "description": "If verification fails, actions may need to be revised or re-implemented.",
   "next_state": "Corrective Action Proposed",
   "state": "Pending Verification"
  }
 ],
 "workflow_name": "NCR Workflow",
 "workflow_state_field": "status"
}
