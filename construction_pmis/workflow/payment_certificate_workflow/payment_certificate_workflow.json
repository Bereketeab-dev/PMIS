{
 "doctype": "Workflow",
 "document_type": "Payment Certificate",
 "is_active": 1,
 "module": "Construction PMIS",
 "name": "Payment Certificate Workflow",
 "send_email_alert": 1,
 "states": [
  {
   "allow_edit": "Quantity Surveyor,Project Manager",
   "doc_status": "0",
   "state": "Draft"
  },
  {
   "allow_edit": "Project Manager,Client Representative,System Manager",
   "doc_status": "1",
   "message": "Payment Certificate submitted. Awaiting approval.",
   "state": "Pending Approval"
  },
  {
   "allow_edit": "Project Manager,Quantity Surveyor,System Manager",
   "doc_status": "1",
   "message": "Payment Certificate approved. Ready for payment processing.",
   "state": "Approved",
   "update_field": "status",
   "update_value": "Approved"
  },
  {
   "allow_edit": "Quantity Surveyor,Project Manager",
   "doc_status": "2",
   "message": "Payment Certificate rejected. Please review and amend.",
   "state": "Rejected"
  },
  {
   "allow_edit": "Accountant,Project Manager,System Manager",
   "doc_status": "1",
   "message": "Payment Certificate processed. Awaiting confirmation of payment.",
   "state": "Processed for Payment",
   "update_field": "status",
   "update_value": "Processed for Payment"
  },
  {
   "allow_edit": "Accountant,System Manager",
   "doc_status": "1",
   "message": "Payment has been made for this certificate.",
   "state": "Paid",
   "update_field": "status",
   "update_value": "Paid"
  },
  {
   "allow_edit": "Project Manager,System Manager",
   "doc_status": "2",
   "message": "Payment Certificate has been cancelled.",
   "state": "Cancelled"
  }
 ],
 "transitions": [
  {
   "action": "Submit for Approval",
   "allow_self_approval": 0,
   "allowed": "Quantity Surveyor,Project Manager",
   "next_state": "Pending Approval",
   "state": "Draft"
  },
  {
   "action": "Approve",
   "allow_self_approval": 0,
   "allowed": "Project Manager,Client Representative,System Manager",
   "condition": "doc.total_amount_due_this_certificate >= 0",
   "next_state": "Approved",
   "state": "Pending Approval"
  },
  {
   "action": "Reject",
   "allow_self_approval": 0,
   "allowed": "Project Manager,Client Representative,System Manager",
   "next_state": "Rejected",
   "state": "Pending Approval"
  },
  {
   "action": "Amend & Resubmit",
   "allow_self_approval": 1,
   "allowed": "Quantity Surveyor,Project Manager",
   "next_state": "Draft",
   "state": "Rejected"
  },
  {
   "action": "Process for Payment",
   "allow_self_approval": 0,
   "allowed": "Accountant,Project Manager,System Manager",
   "custom_action_method": "process_for_payment",
   "next_state": "Processed for Payment",
   "state": "Approved"
  },
  {
   "action": "Mark as Paid",
   "allow_self_approval": 0,
   "allowed": "Accountant,System Manager",
   "custom_action_method": "mark_as_paid",
   "next_state": "Paid",
   "state": "Processed for Payment"
  },
  {
   "action": "Cancel",
   "allowed": "Project Manager,System Manager",
   "next_state": "Cancelled",
   "state": "Approved"
  },
  {
   "action": "Cancel",
   "allowed": "Project Manager,System Manager",
   "next_state": "Cancelled",
   "state": "Pending Approval"
  },
  {
   "action": "Cancel",
   "allowed": "Project Manager,System Manager",
   "next_state": "Cancelled",
   "state": "Rejected"
  }
 ],
 "workflow_name": "Payment Certificate Workflow",
 "workflow_state_field": "status"
}