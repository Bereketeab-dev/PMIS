{
 "doctype": "Workflow",
 "document_type": "Daily Work Plan",
 "is_active": 1,
 "module": "Construction PMIS",
 "name": "Daily Work Plan Workflow",
 "send_email_alert": 0,
 "states": [
  {
   "allow_edit": "Site Engineer,Foreman,Project Manager",
   "doc_status": "0",
   "state": "Draft"
  },
  {
   "allow_edit": "Project Manager,System Manager",
   "doc_status": "1",
   "message": "Daily Work Plan submitted and confirmed.",
   "state": "Planned"
  },
  {
   "allow_edit": "Site Engineer,Project Manager",
   "doc_status": "1",
   "message": "Work for the day is in progress based on this plan.",
   "state": "In Progress"
  },
  {
   "allow_edit": "Project Manager,System Manager",
   "doc_status": "1",
   "message": "All planned activities for the day are reported as completed (via Daily Log).",
   "state": "Completed"
  },
  {
   "allow_edit": "Project Manager,System Manager",
   "doc_status": "2",
   "message": "Daily Work Plan has been cancelled.",
   "state": "Cancelled"
  }
 ],
 "transitions": [
  {
   "action": "Confirm Plan",
   "allow_self_approval": 0,
   "allowed": "Site Engineer,Foreman,Project Manager",
   "condition": "doc.planned_tasks_for_day && doc.planned_tasks_for_day.length > 0",
   "next_state": "Planned",
   "state": "Draft"
  },
  {
   "action": "Start Day's Work",
   "allow_self_approval": 1,
   "allowed": "Site Engineer,Foreman,Project Manager",
   "next_state": "In Progress",
   "state": "Planned"
  },
  {
   "action": "Mark as Completed",
   "allow_self_approval": 0,
   "allowed": "Site Engineer,Project Manager",
   "description": "Typically marked completed after referencing Daily Log for the day.",
   "next_state": "Completed",
   "state": "In Progress"
  },
  {
   "action": "Cancel Plan",
   "allowed": "Project Manager,Site Engineer",
   "next_state": "Cancelled",
   "state": "Planned"
  },
  {
   "action": "Cancel Plan",
   "allowed": "Project Manager",
   "next_state": "Cancelled",
   "state": "In Progress"
  }
 ],
 "workflow_name": "Daily Work Plan Workflow",
 "workflow_state_field": "status"
}
