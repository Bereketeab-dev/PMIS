{
    "doctype": "Workflow",
    "name": "Subcontract Workflow",
    "module": "Construction PMIS",
    "document_type": "Subcontract",
    "workflow_name": "Subcontract Workflow",
    "is_active": 1,
    "send_email_alert": 1,
    "workflow_state_field": "status",
    "states": [
        {
            "state": "Draft",
            "doc_status": "0",
            "allow_edit": "Quantity Surveyor,Contracts Manager,Project Manager"
        },
        {
            "state": "Pending Award",
            "doc_status": "1",
            "allow_edit": "Contracts Manager,Project Manager,System Manager",
            "message": "Subcontract submitted and is pending award."
        },
        {
            "state": "Awarded",
            "doc_status": "1",
            "allow_edit": "Contracts Manager,Project Manager,System Manager",
            "message": "Subcontract has been awarded."
        },
        {
            "state": "Active",
            "doc_status": "1",
            "allow_edit": "Contracts Manager,Project Manager,System Manager",
            "message": "Subcontract is active and work can commence/is ongoing."
        },
        {
            "state": "Completed",
            "doc_status": "1",
            "allow_edit": "System Manager",
            "message": "All works under this subcontract are completed and certified."
        },
        {
            "state": "Terminated",
            "doc_status": "2",
            "allow_edit": "Contracts Manager,Project Manager,System Manager",
            "message": "Subcontract has been terminated."
        },
        {
            "state": "Cancelled",
            "doc_status": "2",
            "allow_edit": "Contracts Manager,Project Manager,System Manager",
            "message": "Subcontract has been cancelled before award/activation."
        }
    ],
    "transitions": [
        {
            "state": "Draft",
            "action": "Submit for Award",
            "next_state": "Pending Award",
            "allowed": "Quantity Surveyor,Contracts Manager,Project Manager",
            "allow_self_approval": 0,
            "condition": "doc.subcontract_value > 0 && doc.supplier"
        },
        {
            "state": "Pending Award",
            "action": "Award Subcontract",
            "next_state": "Awarded",
            "allowed": "Contracts Manager,Project Manager,System Manager",
            "custom_action_method": "award_subcontract"
        },
        {
            "state": "Pending Award",
            "action": "Cancel",
            "next_state": "Cancelled",
            "allowed": "Contracts Manager,Project Manager,System Manager"
        },
        {
            "state": "Awarded",
            "action": "Activate Subcontract",
            "next_state": "Active",
            "allowed": "Contracts Manager,Project Manager",
            "description": "Mark when work officially starts or contract is fully effective."
        },
        {
            "state": "Awarded",
            "action": "Terminate",
            "next_state": "Terminated",
            "allowed": "Contracts Manager,Project Manager,System Manager"
        },
        {
            "state": "Active",
            "action": "Mark as Completed",
            "next_state": "Completed",
            "allowed": "Contracts Manager,Project Manager",
            "description": "Mark once all obligations are fulfilled and final payments processed."
        },
        {
            "state": "Active",
            "action": "Terminate",
            "next_state": "Terminated",
            "allowed": "Contracts Manager,Project Manager,System Manager"
        }
    ]
}
