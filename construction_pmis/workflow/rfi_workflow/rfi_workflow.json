{
    "doctype": "Workflow",
    "name": "RFI Workflow",
    "module": "Construction PMIS",
    "document_type": "RFI",
    "workflow_name": "RFI Workflow",
    "is_active": 1,
    "send_email_alert": 1,
    "workflow_state_field": "status",
    "states": [
        {
            "state": "Open",
            "doc_status": "0",
            "allow_edit": "Site Engineer,Project Manager,Quantity Surveyor"
        },
        {
            "state": "Submitted",
            "doc_status": "1",
            "allow_edit": "Project Manager",
            "message": "RFI submitted. Awaiting response from assigned user."
        },
        {
            "state": "Under Review",
            "doc_status": "1",
            "allow_edit": "User specified in assigned_to field,Project Manager",
            "message": "RFI is under review by the assigned party."
        },
        {
            "state": "Responded",
            "doc_status": "1",
            "allow_edit": "Site Engineer,Project Manager,Quantity Surveyor",
            "message": "Response has been provided. Please review and close if satisfied."
        },
        {
            "state": "Closed",
            "doc_status": "1",
            "allow_edit": "Project Manager,System Manager",
            "update_field": "status",
            "update_value": "Closed",
            "message": "RFI has been closed."
        },
        {
            "state": "Void",
            "doc_status": "2",
            "allow_edit": "Project Manager,System Manager",
            "message": "RFI has been voided."
        }
    ],
    "transitions": [
        {
            "state": "Open",
            "action": "Submit",
            "next_state": "Submitted",
            "allowed": "Site Engineer,Project Manager,Quantity Surveyor",
            "condition": "doc.assigned_to",
            "allow_self_approval": 0
        },
        {
            "state": "Submitted",
            "action": "Assign for Review",
            "next_state": "Under Review",
            "allowed": "Project Manager",
            "allow_self_approval": 0,
            "condition": "doc.assigned_to"
        },
        {
            "state": "Under Review",
            "action": "Provide Response",
            "next_state": "Responded",
            "allowed": "User specified in assigned_to field,Project Manager",
            "condition": "doc.response",
            "allow_self_approval": 1
        },
        {
            "state": "Responded",
            "action": "Close RFI",
            "next_state": "Closed",
            "allowed": "Site Engineer,Project Manager,Quantity Surveyor",
            "allow_self_approval": 0
        },
        {
            "state": "Responded",
            "action": "Request Further Clarification",
            "next_state": "Submitted",
            "allowed": "Site Engineer,Project Manager,Quantity Surveyor",
            "description": "Response is not clear or insufficient. Re-assign or add comments and send back."
        },
        {
            "state": "Submitted",
            "action": "Void RFI",
            "next_state": "Void",
            "allowed": "Project Manager,System Manager"
        },
        {
            "state": "Under Review",
            "action": "Void RFI",
            "next_state": "Void",
            "allowed": "Project Manager,System Manager"
        },
        {
            "state": "Responded",
            "action": "Void RFI",
            "next_state": "Void",
            "allowed": "Project Manager,System Manager"
        },
        {
            "state": "Closed",
            "action": "Reopen RFI",
            "next_state": "Open",
            "allowed": "Project Manager,System Manager",
            "description": "Reopen a closed RFI if further issues arise or response was incorrect."
        }
    ]
}
